{
  "name": "pjl-land-services",
  "version": "1.0.0",
  "private": true,
  "description": "PJL Land Services public site, lead intake, and CRM. Static pages + Node backend.",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "create-user": "node scripts/create-user.js",
    "setup-password": "node scripts/create-user.js",
    "build": "node build.js && node scripts/sync-prices-html.mjs && node scripts/sync-meta-prices.mjs && node worker/rebuild.mjs",
    "build:check": "node build.js --check && node scripts/sync-meta-prices.mjs --check && node scripts/lint-no-hardcoded-prices.mjs && node scripts/lint-qb-mappings.mjs && node scripts/test-pricing.mjs",
    "build:worker": "node worker/rebuild.mjs",
    "sync:meta-prices": "node scripts/sync-meta-prices.mjs",
    "sync:meta-prices:check": "node scripts/sync-meta-prices.mjs --check",
    "sync:body-prices": "node scripts/sync-prices-html.mjs",
    "lint:prices": "node scripts/lint-no-hardcoded-prices.mjs",
    "lint:qb-mappings": "node scripts/lint-qb-mappings.mjs",
    "test:pricing": "node scripts/test-pricing.mjs",
    "migrate:customers": "node scripts/migrate-customers.js",
    "migrate:customers:apply": "node scripts/migrate-customers.js --apply",
    "migrate:customers:backfill": "node scripts/migrate-customers.js --backfill-only",
    "migrate:customers:test-list": "node scripts/migrate-customers.js --list-test-customers",
    "migrate:customers:renumber": "node scripts/migrate-customers.js --renumber",
    "migrate:customers:renumber:apply": "node scripts/migrate-customers.js --renumber --apply"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "nodemailer": "^8.0.7",
    "pdfkit": "^0.17.2"
  }
}
