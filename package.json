{
  "name": "pjl-land-services",
  "version": "1.0.0",
  "private": true,
  "description": "PJL Land Services public site, lead intake, and CRM. Static pages + Node backend.",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "setup-password": "node server/setup-password.js",
    "build": "node build.js && node scripts/sync-meta-prices.mjs && node worker/rebuild.mjs",
    "build:check": "node build.js --check && node scripts/sync-meta-prices.mjs --check",
    "build:worker": "node worker/rebuild.mjs",
    "sync:meta-prices": "node scripts/sync-meta-prices.mjs",
    "sync:meta-prices:check": "node scripts/sync-meta-prices.mjs --check"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "nodemailer": "^8.0.7",
    "pdfkit": "^0.17.2"
  }
}
