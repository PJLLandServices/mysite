# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp
*~

# Working / archive folder (originals before being copied to project root)
Website Build/
Website Photo/
New Whiteboard/

# Local backups / exports — never commit
SYSTEM_OVERVIEW.zip
images/builder.zip

# Audit artifacts
responsive-audit/
audit/captures/
audit/.auth-state.json

# Temp files
*.tmp
*.log

# Memory / Claude project files (don't commit private notes)
memory/
.claude/

# Backend runtime data — never commit. Contains the hashed admin password
# (auth.json) and all real customer leads (leads.json).
server/data/
# Migration safety backups (created by scripts/migrate-customers.js --apply).
# These snapshot server/data/ before a customer migration runs; they live
# only on disk and never get committed.
server/data-backup-*/

# Backend secrets — never commit. Holds Gmail and Twilio credentials.
.env

# Node packages (we have none right now, but in case we add any later)
node_modules/

# Wrangler local cache (contains OAuth tokens)
worker/.wrangler/

# Design / smoke-test PDF outputs — regenerated on demand
_design/_smoke/
