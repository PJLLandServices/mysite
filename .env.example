# PJL Land Services — backend secrets
#
# Copy this file to ".env" (no extension) and fill in real values.
# .env is gitignored — NEVER commit it. Render gets these via its dashboard, not this file.
#
# Until these are set, lead intake still works — emails and SMS just get logged
# to the server console and skipped, instead of being sent. Set them whenever
# you're ready to turn notifications on.

# ============================================================
# Email notifications (Gmail / Google Workspace SMTP)
# ============================================================
# Your Google Workspace email address (e.g. info@pjllandservices.com).
GMAIL_USER=

# A Google "App Password" — NOT your regular Gmail password.
# Create one at: https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be turned on first.)
# It's a 16-character string with no spaces, e.g. "abcdwxyz12345678".
GMAIL_APP_PASSWORD=

# Where the "you got a new lead" email is sent. Defaults to GMAIL_USER if blank.
NOTIFY_TO_EMAIL=

# ============================================================
# SMS notifications (Twilio)
# ============================================================
# Twilio Account SID — starts with "AC". From console.twilio.com -> Account Info.
TWILIO_ACCOUNT_SID=

# Twilio Auth Token — paired with the SID. Same place.
TWILIO_AUTH_TOKEN=

# The Twilio phone number you bought, in E.164 format (with +1 country code).
# Example: +14165550100
TWILIO_FROM_NUMBER=

# Your cell phone — where SMS alerts go. E.164 format.
NOTIFY_TO_PHONE=

# ============================================================
# Public base URL (used to build the "Open in CRM" link in emails/SMS)
# ============================================================
# In production, set to your real domain. In local dev, leave blank — the server
# will use whatever host the request came in on (usually http://127.0.0.1:4173).
PUBLIC_BASE_URL=
